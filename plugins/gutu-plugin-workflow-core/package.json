{
  "name": "gutu-plugin-workflow-core",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/builtin-plugins/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/builtin-plugins/workflow-core build",
    "typecheck": "bun run --cwd framework/builtin-plugins/workflow-core typecheck",
    "lint": "bun run --cwd framework/builtin-plugins/workflow-core lint",
    "test": "bun run --cwd framework/builtin-plugins/workflow-core test",
    "test:contracts": "bun run --cwd framework/builtin-plugins/workflow-core test:contracts",
    "test:unit": "bun run --cwd framework/builtin-plugins/workflow-core test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
