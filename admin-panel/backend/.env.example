# --------------------------------------------------------------------
# Gutu admin-backend — environment configuration
# --------------------------------------------------------------------

# Core
NODE_ENV=development
PORT=8787
DB_PATH=./data.db
PUBLIC_BASE_URL=http://127.0.0.1:8787
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --------------------------------------------------------------------
# Mail plugin — feature flags + secrets
# --------------------------------------------------------------------

# At-rest encryption key. REQUIRED in production.
# Generate one with: openssl rand -base64 32
MAIL_AT_REST_KEY=
# Optional rotation: keep an older key for legacy ciphertexts during migration
MAIL_AT_REST_KEY_OLD=
MAIL_AT_REST_KEY_VERSION=2
MAIL_AT_REST_KEY_OLD_VERSION=1

# OAuth — Google
MAIL_GOOGLE_CLIENT_ID=
MAIL_GOOGLE_CLIENT_SECRET=
# Cloud Pub/Sub topic for Gmail push (full resource name)
MAIL_GOOGLE_PUBSUB_TOPIC=

# OAuth — Microsoft
MAIL_MICROSOFT_CLIENT_ID=
MAIL_MICROSOFT_CLIENT_SECRET=
MAIL_MICROSOFT_TENANT=common
# Public HTTPS URL Graph posts change-notifications to
MAIL_GRAPH_WEBHOOK_URL=

# OAuth — generic OIDC (optional, for Yahoo / Fastmail / on-prem)
MAIL_OIDC_CLIENT_ID=
MAIL_OIDC_CLIENT_SECRET=
MAIL_OIDC_AUTH_URL=
MAIL_OIDC_TOKEN_URL=

# AI provider — none | openai | anthropic | groq | ollama
MAIL_AI_PROVIDER=none
# Per-provider keys (only the chosen provider needs to be set)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MAIL_AI_OLLAMA_URL=http://127.0.0.1:11434

# Specific model overrides (defaults baked into runChat())
# MAIL_AI_OPENAI_MODEL=gpt-4o-mini
# MAIL_AI_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# MAIL_AI_GROQ_MODEL=llama-3.3-70b-versatile
# MAIL_AI_OLLAMA_MODEL=llama3.2

# Embeddings — local (deterministic fallback) | openai | ollama
MAIL_EMBED_PROVIDER=local
MAIL_EMBED_OLLAMA_URL=http://127.0.0.1:11434
# MAIL_EMBED_OPENAI_MODEL=text-embedding-3-small

# Privacy — strip PII before sending to AI providers
MAIL_AI_REDACT=on

# Web push (VAPID). Generate a key pair with the official keygen of your choice.
# Public must be uncompressed P-256 (65 bytes starting with 0x04), base64url.
# Private must be the raw 32-byte scalar, base64url.
MAIL_PUSH_VAPID_PUBLIC=
MAIL_PUSH_VAPID_PRIVATE=
MAIL_PUSH_VAPID_SUBJECT=mailto:ops@example.com

# Image proxy
MAIL_IMAGE_PROXY_MAX_BYTES=5242880   # 5 MiB
MAIL_IMAGE_PROXY_TIMEOUT_MS=10000
# Comma-separated additional tracker hosts to block
MAIL_TRACKER_HOSTS=

# Send pipeline
MAIL_UNDO_SECONDS=10
MAIL_MAX_ATTACHMENT_BYTES=20971520   # 20 MiB
MAIL_MAX_TOTAL_PAYLOAD_BYTES=26214400  # 25 MiB

# Job tick intervals (ms) — increase in production for lighter background load
MAIL_SYNC_TICK_MS=30000
MAIL_SYNC_MAX_PER_FOLDER=50
MAIL_SYNC_HYDRATE_PER_TICK=10
MAIL_SEND_TICK_MS=5000
MAIL_SNOOZE_TICK_MS=60000
MAIL_VACATION_TICK_MS=600000
MAIL_CLEANUP_TICK_MS=1800000
MAIL_INDEX_TICK_MS=60000
MAIL_SUBSCRIBE_TICK_MS=600000
MAIL_OAUTH_REFRESH_TICK_MS=60000
MAIL_RECONCILE_TICK_MS=60000
MAIL_PUSH_TICK_MS=30000

# Demo seed (off by default; set to 1 to populate sample inbox at first boot)
MAIL_SEED_DEMO=0

# Disable jobs (useful for migrations / read-only replicas)
MAIL_DISABLE_JOBS=0
