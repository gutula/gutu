{
  "name": "@workspace/basic-project",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "apps/*",
    "libraries/*",
    "plugins/*",
    "vendor/plugins/*",
    "vendor/libraries/*",
    "vendor/framework/gutu/framework/core/*",
    "vendor/framework/gutu/framework/libraries/*",
    "vendor/framework/gutu/framework/builtin-plugins/*"
  ],
  "scripts": {
    "gutu": "bun run vendor/framework/gutu/framework/core/cli/src/bin.ts",
    "platform": "bun run vendor/framework/gutu/framework/core/cli/src/bin.ts",
    "build": "bun run vendor/framework/gutu/tooling/scripts/workspace-task.mjs build",
    "typecheck": "bun run vendor/framework/gutu/tooling/scripts/workspace-task.mjs typecheck",
    "lint": "bun run vendor/framework/gutu/tooling/scripts/workspace-task.mjs lint",
    "test": "bun run vendor/framework/gutu/tooling/scripts/workspace-task.mjs test",
    "test:unit": "bun run vendor/framework/gutu/tooling/scripts/workspace-task.mjs test:unit",
    "test:integration": "bun run vendor/framework/gutu/tooling/scripts/workspace-task.mjs test:integration",
    "test:e2e": "bun run vendor/framework/gutu/tooling/scripts/workspace-task.mjs test:e2e",
    "test:contracts": "bun run vendor/framework/gutu/tooling/scripts/workspace-task.mjs test:contracts",
    "test:migrations": "bun run vendor/framework/gutu/tooling/scripts/workspace-task.mjs test:migrations",
    "coverage:report": "bun run vendor/framework/gutu/tooling/scripts/workspace-coverage.mjs",
    "docs:scaffold": "bun run gutu -- docs scaffold --all",
    "docs:index": "bun run gutu -- docs index --all --out docs/agent-understanding.index.json",
    "docs:validate": "bun run gutu -- docs validate --all",
    "ci:check": "bun run build && bun run typecheck && bun run lint && bun run docs:validate && bun run test && bun run test:integration && bun run test:contracts && bun run test:migrations && bun run test:e2e"
  }
}
