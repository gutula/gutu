{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "types": ["bun-types", "node", "react", "react-dom"],
    "baseUrl": ".",
    "paths": {
      "@platform/*": [
        "vendor/framework/gutu/framework/core/*/src/index.ts",
        "vendor/framework/gutu/framework/core/*/src/index.tsx",
        "vendor/framework/gutu/framework/libraries/*/src/index.ts",
        "vendor/framework/gutu/framework/libraries/*/src/index.tsx"
      ],
      "@plugins/*": [
        "plugins/*/src/index.ts",
        "plugins/*/src/index.tsx",
        "vendor/plugins/*/src/index.ts",
        "vendor/plugins/*/src/index.tsx",
        "vendor/framework/gutu/framework/builtin-plugins/*/src/index.ts",
        "vendor/framework/gutu/framework/builtin-plugins/*/src/index.tsx"
      ],
      "@apps/*": [
        "apps/*/src/index.ts",
        "apps/*/src/index.tsx"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "artifacts",
    ".gutu"
  ]
}
