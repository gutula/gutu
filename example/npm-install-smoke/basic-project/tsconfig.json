{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "libraries/**/*.ts",
    "libraries/**/*.tsx",
    "plugins/**/*.ts",
    "plugins/**/*.tsx",
    "vendor/plugins/**/*.ts",
    "vendor/plugins/**/*.tsx",
    "vendor/libraries/**/*.ts",
    "vendor/libraries/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "artifacts",
    ".gutu"
  ]
}
